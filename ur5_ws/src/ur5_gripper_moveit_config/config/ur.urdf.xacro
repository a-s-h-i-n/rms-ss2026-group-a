<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ur">
    <xacro:arg name="ur_type" default="ur5"/>
    <xacro:arg name="sim_gazebo" default="true"/>
    <xacro:arg name="initial_positions_file" default="$(find ur5_path_planning)/config/initial_positions.yaml"/>
    <xacro:property name="initial_positions_file" value="$(arg initial_positions_file)"/>
    <xacro:include filename="$(find ur5_path_planning)/urdf/ur5_gripper.urdf.xacro" />
</robot>

